OPENAI_BASE_URL=http://host.docker.internal:8001/v1
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL_TEXT=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o-mini
ISOLATION_MODE=docker_task
SANDBOX_IMAGE=websandbox-worker:latest
SANDBOX_NETWORK=websandbox_default
GOVERNANCE_API_KEY=your-governance-api-key
MODEL_ARTIFACT_DIR=/app/models
ALLOW_PRIVATE_TARGET_URLS=false
ALLOW_PRIVATE_CALLBACK_URLS=false
CRAWL_TIMEOUT_QUICK_SECONDS=20
CRAWL_TIMEOUT_STANDARD_SECONDS=30
CRAWL_TIMEOUT_DEEP_SECONDS=45
MAX_DOM_CHARS=600000
MAX_NETWORK_EVENTS=300
MAX_REDIRECT_CHAIN=20
SANDBOX_TIMEOUT_RETRIES=1
SANDBOX_RETRY_TIMEOUT_MULTIPLIER=1.5
SANDBOX_FALLBACK_TO_LOCAL_ON_TIMEOUT=true
SANDBOX_FALLBACK_TIMEOUT_SECONDS=45
CELERY_TASK_TIME_LIMIT_SECONDS=300
QUEUE_QUICK=quick
QUEUE_STANDARD=standard
QUEUE_DEEP=deep
QUEUE_RETRY=retry
WORKER_QUEUES=quick,standard,deep,retry
API_HOST_PORT=8000
REDIS_HOST_PORT=16379
POSTGRES_HOST_PORT=15432
MINIO_HOST_PORT=19000
MINIO_CONSOLE_HOST_PORT=19001
# CALLBACK_ALLOWLIST=hooks.example.com,security.example.com
